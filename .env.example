# Preencha com os valores do seu projeto Supabase.
# Encontre em: Supabase → Settings → API

VITE_SUPABASE_URL=https://SEUPROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_chave_anon_aqui

# E-mail do ÚNICO usuário do app (o seu).
# Este e-mail é usado no login — você só digita a senha.
VITE_APP_EMAIL=seuemail@exemplo.com
